{
  "buildCommand": null,
  "outputDirectory": "docs",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/privacy",
      "destination": "https://docs.deepshare.app/privacy/",
      "permanent": true
    },
    {
      "source": "/privacy.html",
      "destination": "https://docs.deepshare.app/privacy/",
      "permanent": true
    },
    {
      "source": "/terms",
      "destination": "https://docs.deepshare.app/terms/",
      "permanent": true
    },
    {
      "source": "/terms.html",
      "destination": "https://docs.deepshare.app/terms/",
      "permanent": true
    },
    {
      "source": "/privacy-en",
      "destination": "https://docs.deepshare.app/en/privacy/",
      "permanent": true
    },
    {
      "source": "/privacy-en.html",
      "destination": "https://docs.deepshare.app/en/privacy/",
      "permanent": true
    },
    {
      "source": "/terms-en",
      "destination": "https://docs.deepshare.app/en/terms/",
      "permanent": true
    },
    {
      "source": "/terms-en.html",
      "destination": "https://docs.deepshare.app/en/terms/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Content-Language",
          "value": "zh-CN"
        },
        {
          "key": "Vary",
          "value": "Accept-Language"
        }
      ]
    },
    {
      "source": "/index-en.html",
      "headers": [
        {
          "key": "Content-Language",
          "value": "en"
        },
        {
          "key": "Vary",
          "value": "Accept-Language"
        }
      ]
    }
  ]
}
